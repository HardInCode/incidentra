# Incidentra — Docker (copy to .env.docker before compose up)
#   copy .env.docker.example .env.docker
# Database/Redis URLs are set in docker-compose.yml (not here).

FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Demo SOC users — set explicit passwords here, or leave blank to auto-generate a random
# password on first seed (printed ONCE to `docker compose logs backend`, never stored in plaintext).
DEMO_ADMIN_PASSWORD=
DEMO_ANALYST_PASSWORD=

GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
ABUSEIPDB_API_KEY=

USE_SIMULATED_LOGS=false
DEMO_MODE=false
WEB_SERVER_LOG_PATH=/app/watched_logs/access.log
BLOCKED_IPS_JSON_PATH=/app/watched_logs/blocked_ips.json
RATE_LIMITED_JSON_PATH=/app/watched_logs/rate_limited.json

TEMP_BLOCK_DURATION=86400
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=10
BRUTE_FORCE_THRESHOLD=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
