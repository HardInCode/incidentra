# ============================================================
# Incidentra Backend — Manual (local Windows/Linux)
# Copy to .env before: python run.py
# Docker: pakai backend/.env.docker (lihat docs/GUIDE.md)
# ============================================================

FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Demo SOC users (PostgreSQL table users — seeded on startup, password stored hashed)
# SYNC_DEMO_CREDENTIALS=1 refreshes admin/analyst passwords when backend starts (capstone default)
SYNC_DEMO_CREDENTIALS=1
DEMO_ADMIN_PASSWORD=Admin@Incidentra2026!
DEMO_ANALYST_PASSWORD=Analyst@Incidentra2026!
# CORS_ORIGINS=http://192.168.1.50:3000

# PostgreSQL & Redis (localhost)
DATABASE_URL=postgresql://incidentra:incidentra123@localhost:5432/incidentra_db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI (optional — https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Threat intel (optional)
ABUSEIPDB_API_KEY=

# Log monitor — first run: simulated; after vuln-web up: switch to false + paths below
USE_SIMULATED_LOGS=true
DEMO_MODE=true
SIMULATED_LOG_DELAY=5
WEB_SERVER_LOG_PATH=../vuln-web/logs/access.log
LOG_MONITOR_INTERVAL=1
BLOCKED_IPS_JSON_PATH=../vuln-web/logs/blocked_ips.json
RATE_LIMITED_JSON_PATH=../vuln-web/logs/rate_limited.json

# Response
TEMP_BLOCK_DURATION=86400
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=10
BRUTE_FORCE_THRESHOLD=10
# DETECTION_LAB_MODE_UI_ONLY=false   # or set in SOC Settings (DB); true = UI rules only, no OWASP baseline

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
